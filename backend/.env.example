# OpenAI API (Required) - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Bank of Korea ECOS API (Required, Free) - https://ecos.bok.or.kr/api/
ECOS_API_KEY=your-ecos-key-here

# OpenDART (Optional, Free) - https://opendart.fss.or.kr/intro/main.do
OPENDART_API_KEY=your-opendart-key-here

# KOSIS Open API (Optional, Free) - https://kosis.kr/openapi/index/index.jsp
KOSIS_API_KEY=your-kosis-key-here
KOSIS_CPI_STATS_ID=
KOSIS_EMPLOYMENT_STATS_ID=
KOSIS_INDUSTRIAL_PRODUCTION_STATS_ID=

# Naver Search API (Optional, Free) - https://developers.naver.com/docs/serviceapi/search/news/news.md
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# Financial Modeling Prep (Optional, Free Basic) - https://financialmodelingprep.com/developer/docs/
FMP_API_KEY=your-fmp-key-here

# Database
DB_PATH=data/stock_predict.db
SUPABASE_URL=
SUPABASE_SERVER_KEY=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=
FRONTEND_ORIGIN_REGEX=

# Optional startup controls
STARTUP_PREDICTION_ACCURACY_REFRESH=true
STARTUP_PREDICTION_ACCURACY_REFRESH_TIMEOUT=20
STARTUP_RESEARCH_ARCHIVE_SYNC=true
STARTUP_RESEARCH_ARCHIVE_SYNC_TIMEOUT=35
STARTUP_MARKET_OPPORTUNITY_PREWARM=true
STARTUP_MARKET_OPPORTUNITY_PREWARM_TIMEOUT=180

# Monitoring (optional)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
